# Copy to .env.local. For local Supabase the values are printed by `supabase start`.
# These are the standard local-dev defaults (safe to commit — local only).
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-anon-key-from-supabase-start
# Server-only (owner user-management). Never prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key-from-supabase-start
